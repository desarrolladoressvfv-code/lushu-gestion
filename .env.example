# Copia este archivo como .env y completa los valores

# URL de tu proyecto en Supabase (Settings > API)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clave pública anon de Supabase (Settings > API)
VITE_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxx

# ID del cliente en la tabla "clientes" de Supabase
# Este valor identifica a qué cliente pertenece esta instalación
VITE_CLIENTE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
